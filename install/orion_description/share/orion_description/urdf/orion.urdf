<?xml version="1.0" encoding="utf-8"?>
<robot name="orion">

  <!-- ==================== LINKS ==================== -->
  <!-- mesh path relative to this urdf when installed: ../meshes/stl/ -->

  <link name="base_link">
    <visual>
      <geometry><mesh filename="../meshes/stl/base_link.stl"/></geometry>
      <material name="grey"><color rgba="0.7 0.7 0.7 1.0"/></material>
    </visual>
    <collision>
      <geometry><mesh filename="../meshes/stl/base_link.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <link name="Link1">
